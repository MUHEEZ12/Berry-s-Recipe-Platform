/* RecipesPage.css - Recipes browse/filter page styling */

.recipes-page-container {
  min-height: calc(100vh - 140px);
  background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  padding: 40px 20px;
}

.recipes-page-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 32px;
  max-width: 1400px;
  margin: 0 auto;
  align-items: start;
}

.recipes-sidebar {
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 0;
  height: fit-content;
  position: sticky;
  top: 100px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  overflow: auto;
  z-index: 5;
}

.sidebar-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  padding: 20px 24px;
  margin-bottom: 0;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.05) 0%, rgba(78, 205, 196, 0.05) 100%);
  border-bottom: 2px solid var(--border-color);
  letter-spacing: 0.3px;
}

.filter-group {
  padding: 24px;
  border-bottom: 1px solid var(--border-color);
}

.filter-group:last-child {
  border-bottom: none;
}

.filter-label {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.filter-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.filter-checkbox {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--transition-fast);
  background: transparent;
}

.filter-checkbox:hover {
  background: var(--bg-secondary);
  transform: translateX(4px);
}

.filter-checkbox input[type="checkbox"] {
  cursor: pointer;
  accent-color: var(--primary);
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

.filter-checkbox label {
  flex: 1;
  font-size: 0.9rem;
  color: var(--text-secondary);
  margin-bottom: 0;
  cursor: pointer;
  user-select: none;
}

.filter-checkbox input[type="checkbox"]:checked + label {
  color: var(--text-primary);
  font-weight: 600;
}

.clear-filters {
  margin: 24px 24px 0 24px;
  padding: 12px 16px;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border: none;
  border-radius: var(--radius-md);
  color: white;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all var(--transition-fast);
  width: calc(100% - 48px);
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.clear-filters:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 12px rgba(255, 107, 107, 0.25);
}

.clear-filters:active {
  transform: translateY(0);
}

/* Recipes Page Container */
.recipes-page {
  display: flex;
  flex-direction: column;
  gap: 24px;
  overflow: visible;
}

/* Recipe Controls */
.recipes-control {
  display: flex;
  flex-direction: column;
  gap: 20px;
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  overflow: visible;
  position: relative;
  z-index: 50;
  margin-bottom: 24px;
}

.search-box {
  position: relative;
  width: 100%;
}

.search-box input {
  width: 100%;
  padding: 14px 16px 14px 40px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 0.95rem;
  background: var(--bg-secondary);
  color: var(--text-primary);
  transition: all var(--transition-fast);
}

.search-box input::placeholder {
  color: var(--text-secondary);
}

.search-box input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(255, 107, 107, 0.1);
  background: var(--bg-primary);
}

.search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 1.2rem;
  color: var(--text-secondary);
  pointer-events: none;
}

/* Filters */
.filters {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  flex-wrap: wrap;
  position: relative;
  z-index: 100;
  margin-bottom: 8px;
}

.filter-select {
  padding: 12px 14px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  background: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 0.9rem;
  cursor: pointer;
  transition: all var(--transition-fast);
  font-weight: 500;
  min-width: 150px;
  position: relative;
  z-index: 1000;
  display: block;
}

/* Sort Button */
.sort-button {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  background: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-fast);
  min-width: 140px;
  justify-content: center;
}

.sort-button:hover {
  border-color: var(--primary);
  background-color: var(--bg-primary);
}

/* Sort Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1998;
  animation: fadeIn 0.2s ease-out;
}

/* Sort Modal */
.sort-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-primary);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 20px;
  z-index: 1999;
  animation: slideUp 0.3s ease-out;
  max-height: 70vh;
  overflow-y: auto;
}

.sort-modal-header {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--border-color);
}

/* Sort Options */
.sort-options {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sort-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  background: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.sort-option:hover {
  background: var(--bg-primary);
  border-color: var(--primary);
  transform: translateX(4px);
}

.sort-option.active {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(78, 205, 196, 0.1) 100%);
  border-color: var(--primary);
  font-weight: 600;
}

.checkmark {
  color: var(--primary);
  font-size: 1.1rem;
  font-weight: 700;
}

/* Animations */
@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.filter-select {

/* Category Pills */
.category-pills {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  flex: 1;
  min-width: 300px;
}

.pill {
  padding: 10px 20px;
  background: transparent;
  border: 2px solid var(--border-color);
  border-radius: 20px;
  color: var(--text-secondary);
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}

.pill::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s ease;
}

.pill:hover {
  border-color: var(--primary);
  color: var(--primary);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(255, 107, 107, 0.15);
}

.pill:hover::before {
  left: 100%;
}

.pill.active {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-color: var(--primary);
  color: white;
  box-shadow: 0 6px 16px rgba(255, 107, 107, 0.3);
}

.pill.active:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 20px rgba(255, 107, 107, 0.35);
}

/* Main Content */
.recipes-main {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.recipes-header {
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  flex-wrap: wrap;
  gap: 16px;
}

.recipes-search {
  display: flex;
  gap: 12px;
  flex: 1;
  min-width: 250px;
}

.search-input {
  flex: 1;
  padding: 12px 16px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 0.95rem;
  background: var(--bg-secondary);
  color: var(--text-primary);
  transition: all var(--transition-fast);
}

.search-input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(255, 107, 107, 0.1);
  background: var(--bg-primary);
}

.search-button {
  padding: 12px 24px;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: white;
  border: none;
  border-radius: var(--radius-md);
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
  white-space: nowrap;
}

.search-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(255, 107, 107, 0.3);
}

.recipes-sort {
  display: flex;
  align-items: center;
  gap: 12px;
}

.sort-label {
  font-weight: 500;
  color: var(--text-secondary);
  white-space: nowrap;
}

.sort-select {
  padding: 10px 14px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  background: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 0.9rem;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.sort-select:hover {
  border-color: var(--primary);
}

.sort-select:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(255, 107, 107, 0.1);
}

/* Recipes Grid */
.recipes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
  gap: 18px;
  animation: fadeIn 0.3s ease-out;
}

/* Recipe card styles moved to Card.css for better organization */

/* Empty State */
.empty-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: 60px 40px;
  background: var(--bg-primary);
  border: 2px dashed var(--border-color);
  border-radius: var(--radius-lg);
}

.empty-state-icon {
  font-size: 3rem;
  margin-bottom: 16px;
}

.empty-state-title {
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.empty-state-text {
  font-size: 1rem;
  color: var(--text-secondary);
  margin-bottom: 24px;
}

.empty-state-button {
  padding: 12px 24px;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: white;
  border: none;
  border-radius: var(--radius-md);
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.empty-state-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(255, 107, 107, 0.3);
}

/* Skeleton Loading */
.recipes-grid-skeleton {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 24px;
}

.skeleton-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.skeleton-image {
  height: 200px;
  background: linear-gradient(90deg, var(--border-color) 25%, var(--bg-tertiary, #f5f5f5) 50%, var(--border-color) 75%);
  background-size: 200% 100%;
  animation: pulse 1.5s infinite;
}

.skeleton-content {
  padding: 16px;
}

.skeleton-line {
  height: 12px;
  background: linear-gradient(90deg, var(--border-color) 25%, var(--bg-tertiary, #f5f5f5) 50%, var(--border-color) 75%);
  background-size: 200% 100%;
  animation: pulse 1.5s infinite;
  margin-bottom: 12px;
  border-radius: 4px;
}

.skeleton-line.title {
  height: 16px;
  margin-bottom: 16px;
  width: 90%;
}

.skeleton-line.small {
  height: 10px;
  width: 70%;
}

/* Universal Responsive - Works for All Screen Sizes */
@media (max-width: 1024px) {
  .recipes-page-layout {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .recipes-sidebar {
    position: static;
    display: flex;
    flex-direction: column;
  }
}

@media (max-width: 768px) {
  .recipes-page-container {
    padding: 20px 12px;
  }

  .recipes-control {
    padding: 20px;
    gap: 16px;
  }

  .filters {
    flex-direction: column;
    gap: 12px;
  }

  .sort-button {
    width: 100%;
  }

  .category-pills {
    width: 100%;
    justify-content: flex-start;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .recipes-grid {
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 12px;
  }

  .recipe-card-image {
    height: 120px;
  }
}

@media (max-width: 480px) {
  .recipes-page-container {
    padding: 16px 12px;
  }

  .recipes-control {
    padding: 16px;
    gap: 12px;
    margin-bottom: 16px;
  }

  .search-box input {
    padding: 12px 12px 12px 36px;
    font-size: 0.9rem;
  }

  .search-icon {
    left: 10px;
    font-size: 1rem;
  }

  .filters {
    flex-direction: column;
    gap: 10px;
  }

  .sort-button {
    width: 100%;
    padding: 12px;
    font-size: 0.9rem;
  }

  .sort-button span {
    display: inline;
  }

  .category-pills {
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 8px;
  }

  .pill {
    padding: 8px 12px;
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .recipes-sidebar {
    padding: 12px;
  }

  .filter-group {
    padding: 16px;
    margin-bottom: 12px;
  }

  .recipes-grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .recipe-card-image {
    height: 120px;
  }

  .recipe-card-content {
    padding: 12px;
  }

  .recipe-card-title {
    font-size: 0.9rem;
  }

  .recipe-card-description {
    font-size: 0.75rem;
  }

  .empty-state {
    padding: 30px 15px;
  }

  .empty-state-icon {
    font-size: 2rem;
  }

  .empty-state-title {
    font-size: 1.1rem;
  }
}

/* Dark mode */
body.dark-mode .recipes-page,
body.dark-mode .recipes-sidebar,
body.dark-mode .recipes-header,
body.dark-mode .recipes-control,
body.dark-mode .recipe-card,
body.dark-mode .empty-state {
  background: var(--bg-primary);
  border-color: var(--border-color);
}

body.dark-mode .sort-button {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border-color: var(--border-color);
}

body.dark-mode .sort-button:hover {
  background: var(--bg-primary);
  border-color: var(--primary);
}

body.dark-mode .sort-modal {
  background: var(--bg-primary);
  color: var(--text-primary);
}

body.dark-mode .sort-modal-header {
  border-color: var(--border-color);
}

body.dark-mode .sort-option {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border-color: var(--border-color);
}

body.dark-mode .sort-option:hover {
  background: var(--bg-primary);
  border-color: var(--primary);
}

body.dark-mode .sort-option.active {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(78, 205, 196, 0.1) 100%);
  border-color: var(--primary);
}

body.dark-mode .skeleton-image,
body.dark-mode .skeleton-line {
  background: var(--bg-secondary);
}

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-primary);
}

::-webkit-scrollbar-thumb {
  background: var(--border-color);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-tertiary);
}

/* Dark Mode Scrollbar */
body.dark-mode ::-webkit-scrollbar-track {
  background: var(--bg-secondary);
}

body.dark-mode ::-webkit-scrollbar-thumb {
  background: var(--text-tertiary);
  border-radius: 4px;
}

body.dark-mode ::-webkit-scrollbar-thumb:hover {
  background: var(--text-secondary);
}
